ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# Context window (tokens) for generate_node/clarify_node's Ollama calls --
# covers the full SDD text plus up to 30 RAG chunks, which can exceed 16k
# tokens. Leaving this unset before it existed caused silent prompt
# truncation once the model was already loaded with a smaller context size.
# Lower this if your hardware can't hold that much KV cache without a
# heavy slowdown.
OLLAMA_NUM_CTX=32768

CHROMA_PERSIST_PATH=./chroma_db
NOTION_API_KEY=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
NOTION_DATABASE_ID=ai-ba
NOTION_PARENT_PAGE_ID=https://app.notion.com/p/c45ed9a6cb4f46a9b59823b0a73198ee?v=f187017a5e9b4e0ea1220a6107402931&source=copy_link

MCP_SERVER_PATH=
ADO_ORGANIZATION=
ADO_PROJECT=
NOTION_TITLE_PROPERTY=Task
NOTION_STATUS_PROPERTY=Status
NOTION_STATUS_VALUE=To Do

CORS_ORIGINS=http://localhost:4200

# Signs the login JWT. Leave unset and this app will auto-generate+persist a
# random one under JOBS_DIR/.jwt_secret, which is fine for local dev -- set
# it explicitly before exposing this beyond local testing.
JWT_SECRET=

JOBS_DIR=./jobs
UPLOADS_DIR=./uploads
EXPORTS_DIR=./exports

# "production" (default) or "selftest" — selftest swaps in a prompt variant
# for assessing SDDs about StoryForge AI's own codebase. Leave unset for real use.
PROMPT_VARIANT=production

# "document" (default) writes approved stories to a .docx, downloadable via
# GET /export/document/{job_id}. Set to "ado" to push to Azure DevOps, or
# "notion" to push to a Notion database (see NOTION_* settings above).
OUTPUT_MODE=document

# ingestion/enrichment/'s optional per-file LLM-summary tier. Ingestion uses
# ANTHROPIC_API_KEY/CLAUDE_MODEL above by default; enable Ollama as a second
# agent (round-robin) with the two lines below.
INGEST_OLLAMA_ENABLED=false
INGEST_OLLAMA_MODEL=qwen2.5:14b

# "claude" (default) or "ollama" -- which model answers the Ask Technical/
# Ask Business endpoints.
ASK_QA_MODEL=claude

# Shared HTTP request timeout (seconds) for every LLM call in this app: Ask
# Technical/Business, StoryForge's generate/clarify nodes, and ingestion's
# LLM-summary enrichment agents. Raise this if a slower local Ollama model
# needs more time than the default to finish a response.
LLM_REQUEST_TIMEOUT_SECONDS=300

# Ingestion's optional per-file LLM-summary enrichment tier (on by default).
INGEST_LLM_SUMMARY_ENABLED=true
