ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

CHROMA_PERSIST_PATH=./chroma_db
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_PARENT_PAGE_ID=

MCP_SERVER_PATH=
ADO_ORGANIZATION=
ADO_PROJECT=
NOTION_TITLE_PROPERTY=Task
NOTION_STATUS_PROPERTY=Status
NOTION_STATUS_VALUE=To Do

CORS_ORIGINS=http://localhost:4200

JOBS_DIR=./jobs
UPLOADS_DIR=./uploads
EXPORTS_DIR=./exports

# "production" (default) or "selftest" — selftest swaps in a prompt variant
# for assessing SDDs about StoryForge AI's own codebase. Leave unset for real use.
PROMPT_VARIANT=production

# "document" (default) writes approved stories to a .docx, downloadable via
# GET /export/document/{job_id}. Set to "ado" to push to Azure DevOps, or
# "notion" to push to a Notion database (see NOTION_* settings above).
OUTPUT_MODE=document
