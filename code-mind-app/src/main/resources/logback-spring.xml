<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Pulls in Spring Boot's default console appender/pattern (CONSOLE_LOG_PATTERN,
         etc.), so nothing about existing console logging changes; this file only
         adds the error-capture appender on top of it. -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="ERROR_CAPTURE" class="com.jslogicextractor.monitoring.ErrorCaptureAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ERROR_CAPTURE"/>
    </root>

    <logger name="com.jslogicextractor" level="INFO"/>
</configuration>
